strategy("SMC Engine — Strategy", overlay = true, initial_capital = 10000, default_qty_type = strategy.percent_of_equity, default_qty_value = 1, commission_type = strategy.commission.cash_per_contract, process_orders_on_close = true)

// === INPUTS ===
// Grupos canonicos (reglas-dev §1.3). Esqueleto: solo inputs base; el resto
// (toggles por concepto, pesos w_* del scoring) llega en sus tareas.
GRP_STRUCT = "Estructura"
GRP_OB     = "Order Blocks"
GRP_SCORE  = "Scoring"
i_swingLen    = input.int(5, "Swing length",    minval = 2, group = GRP_STRUCT)
i_internalLen = input.int(3, "Internal length", minval = 1, group = GRP_STRUCT)
i_obHighVolFactor = input.float(2.0, "Filtro volatilidad (x ATR200)", minval = 0.5, step = 0.1, group = GRP_OB)
i_obMitClose     = input.bool(false, "Mitigacion por cierre (vs mecha)",  group = GRP_OB)
i_scoreThresh = input.int(0, "Score threshold (calibrar Fase 3)", group = GRP_SCORE)

// === LIBRARY CORE ===
// ---------------------------------------------------------------------------
// Nucleo de deteccion SMC/ICT. BYTE-IDENTICO en SMC-Visual y SMC-Strategy
// (lo vigila scripts/check-core-sync.ps1 — regla dura #2). El core NO dibuja y
// NO llama request.security(): solo tipos, constantes y funciones puras
// (entradas -> detecciones). La version exportable equivalente vive en
// SMC-Library.pine [D-PINE-01]. Esqueleto F1-S1.1-T01: tipos + constantes +
// arrays acotados; las f_detect*/f_compute* se añaden en T02+.
// ---------------------------------------------------------------------------
// Constantes 'kind' por categoria [reglas-dev §1.2 · PINE-PLAN §2]
KIND_OB          = 1
KIND_FVG         = 2
KIND_BREAKER     = 3
KIND_REJECTION   = 4
KIND_MITIGATION  = 5
KIND_OTE         = 6
KIND_GP          = 7
KIND_BOS          = 20
KIND_CHOCH        = 21
KIND_MSS          = 22
KIND_SWEEP        = 23
KIND_GRAB         = 24
KIND_JUDAS        = 25
KIND_DISPLACEMENT = 26
KIND_IDM          = 27
KIND_EMACROSS     = 28
KIND_EMABOUNCE    = 29
KIND_FLIP         = 30
KIND_HH = 40
KIND_HL = 41
KIND_LH = 42
KIND_LL = 43
DIR_BULL     = 1
DIR_BEAR     = -1
ZS_ACTIVE    = 0
ZS_PARTIAL   = 1
ZS_MITIGATED = 2
ZS_INVALID   = 3
MAX_ZONES  = 50
MAX_EVENTS = 100
MAX_SWINGS = 100
MAX_POOLS  = 50
MAX_BARBUF = 500
type SMC_Zone
    float  top
    float  bottom
    int    dir
    int    barIdx
    int    barTime
    int    state        = 0
    float  mitigatedPct = 0.0
    string tf           = ""
    int    kind         = 0
type SMC_Event
    float  price
    int    dir
    int    barIdx
    int    barTime
    string tf   = ""
    int    kind = 0
type SMC_Swing
    float  price
    int    barIdx
    int    barTime
    int    kind   = 0
    bool   swept  = false
    bool   isHigh = false
type SMC_Pool
    float  level
    int    dir
    int    touches  = 1
    int    barTime
    bool   swept    = false
    string tf       = ""
type SMC_TFState
    int    bias           = 0
    float  lastBOSPrice   = na
    int    lastBOSDir     = 0
    int    lastBOSTime    = 0
    float  lastCHoCHPrice = na
    int    lastCHoCHDir   = 0
    int    lastCHoCHTime  = 0
    float  pdHigh         = na
    float  pdLow          = na
    float  ema20          = na
    float  ema50          = na
    float  ema200         = na
f_pushZone(array<SMC_Zone> a, SMC_Zone z, int maxN) =>
    array.push(a, z)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushEvent(array<SMC_Event> a, SMC_Event e, int maxN) =>
    array.push(a, e)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushSwing(array<SMC_Swing> a, SMC_Swing s, int maxN) =>
    array.push(a, s)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushPool(array<SMC_Pool> a, SMC_Pool p, int maxN) =>
    array.push(a, p)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)

