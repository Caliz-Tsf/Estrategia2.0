// --- Swings + clasificacion HH/HL/LH/LL [reglas-smc-ict §1.1/§1.2] · T02 ---
// f_detectSwings: pivote simetrico estricto. high[len] > high de las len velas a
// cada lado (low simetrico). Equivale a ta.pivothigh/low(len, len). Confirmado al
// cierre de la vela t+len -> latencia len velas, cero repaint [§1.1]. Devuelve
// [precioHigh, precioLow] del pivote centrado len velas atras; na si no hay.
f_detectSwings(int len) =>
    [ta.pivothigh(len, len), ta.pivotlow(len, len)]

// f_classifySwing: etiqueta el swing recien confirmado contra el swing previo del
// MISMO tipo (high vs high, low vs low) [§1.2]. isHigh = true si es swing high.
// Recorre los swings almacenados de atras hacia adelante hasta el ultimo del mismo
// tipo. Igualdad exacta de precio: no reclasifica -> hereda el kind previo
// (candidato EQH/EQL). Primer swing del tipo (sin referencia): seed HH/LL.
// INVARIANTE [T02 · obs. validador 97/100]: la clasificacion filtra por tipo
// (sHigh == isHigh), asi que un swing high y un swing low confirmados en la MISMA
// vela t (caso spike, casi imposible con swingLen=5 en H1) se etiquetan de forma
// independiente y NO interfieren. No se asume alternancia high/low aguas abajo:
// BOS/CHoCH/MSS/EQH/EQL leen por tipo. Anotado para revision Fable pre-Fase 4
// (docs/notas-revision-fable.md) por paridad MQL5 (golden tests, ADR-002).
f_classifySwing(bool isHigh, float price, array<SMC_Swing> swings) =>
    int   prevKind  = na
    float prevPrice = na
    if array.size(swings) > 0
        for i = array.size(swings) - 1 to 0
            SMC_Swing s = array.get(swings, i)
            bool sHigh = s.kind == KIND_HH or s.kind == KIND_LH
            if sHigh == isHigh
                prevKind  := s.kind
                prevPrice := s.price
                break
    int kind = na
    if isHigh
        kind := na(prevPrice) ? KIND_HH : price > prevPrice ? KIND_HH : price < prevPrice ? KIND_LH : prevKind
    else
        kind := na(prevPrice) ? KIND_LL : price > prevPrice ? KIND_HL : price < prevPrice ? KIND_LL : prevKind
    kind

// --- Estructura de mercado: BOS / CHoCH [reglas-smc-ict §1.3/§1.4] · T03 ---
// Modelo de bias estructural (reglas, seccion "Modelo de bias estructural"): por
// escala se mantiene el ultimo swing high y el ultimo swing low confirmados
// (highLevel/lowLevel) con un flag 'crossed' que evita re-disparar sobre el mismo
// nivel, y un 'bias' (+1/-1) fijado por la ultima ruptura. La distincion BOS vs
// CHoCH la da el bias vigente al romper [reglas §1.3/§1.4]:
//   - close rompe el nivel que EXTIENDE la tendencia -> BOS  (continuacion).
//   - close rompe el nivel que PROTEGE  la tendencia -> CHoCH (cambio de caracter).
// Ruptura por CIERRE estricto (close > highLevel / close < lowLevel), NO por mecha
// [§1.3]; el flag 'crossed' replica el 'topBroken/btmBroken' del oraculo de paridad
// scripts/ver05/detect.py (ADR-002) y el 'pivot.crossed' de LuxAlgo displayStructure
// (ref :551-612, v5->v6). El guard barstate.isconfirmed (en DETECCION) hace que el
// cierre que rompe sea definitivo -> anti-repaint [D-PINE-03]. Escala swing
// (swingLen) y escala interna (internalLen) se trackean en SMC_Structure separados;
// el bias mayor es el de la escala swing: una ruptura INTERNA no voltea el bias swing
// [§1.4]. okHigh/okLow permiten el guard de nivel-distinto del interno (no duplicar
// la senal swing cuando el pivote interno coincide, cf. LuxAlgo extraCondition
// internalHigh.currentLevel != swingHigh.currentLevel).
type SMC_Structure
    float highLevel   = na
    int   highBarIdx  = na
    int   highTime    = na
    bool  highCrossed = false
    float lowLevel    = na
    int   lowBarIdx   = na
    int   lowTime     = na
    bool  lowCrossed  = false
    int   bias        = 0

// f_setStructureHigh/Low: fija un swing recien confirmado como nivel estructural
// vigente y resetea 'crossed' (nivel fresco, aun no roto). Por construccion del
// pivote, el close de la barra de confirmacion nunca rompe el nivel recien fijado.
f_setStructureHigh(SMC_Structure st, float price, int barIdx, int barTime) =>
    st.highLevel   := price
    st.highBarIdx  := barIdx
    st.highTime    := barTime
    st.highCrossed := false

f_setStructureLow(SMC_Structure st, float price, int barIdx, int barTime) =>
    st.lowLevel   := price
    st.lowBarIdx  := barIdx
    st.lowTime    := barTime
    st.lowCrossed := false

// f_detectStructure: evalua ruptura por cierre del nivel estructural vigente y, si
// hay, muta el estado (crossed + bias) y devuelve el SMC_Event (na si no hay).
// Prioriza el lado alcista (else-if): un mismo close no puede superar el highLevel y
// perforar el lowLevel salvo niveles invertidos, caso que no ocurre con estructura
// sana; el oraculo ver05 usa dos if separados y produce la misma lista en la ventana
// validada. price = nivel roto; barIdx/barTime = barra de ruptura; kind = BOS|CHoCH.
f_detectStructure(SMC_Structure st, int breakBarIdx, int breakTime, bool okHigh, bool okLow) =>
    SMC_Event ev = na
    if okHigh and not na(st.highLevel) and not st.highCrossed and close > st.highLevel
        int tag = st.bias == DIR_BEAR ? KIND_CHOCH : KIND_BOS
        st.highCrossed := true
        st.bias        := DIR_BULL
        ev := SMC_Event.new(st.highLevel, DIR_BULL, breakBarIdx, breakTime, "", tag)
    else if okLow and not na(st.lowLevel) and not st.lowCrossed and close < st.lowLevel
        int tag = st.bias == DIR_BULL ? KIND_CHOCH : KIND_BOS
        st.lowCrossed := true
        st.bias        := DIR_BEAR
        ev := SMC_Event.new(st.lowLevel, DIR_BEAR, breakBarIdx, breakTime, "", tag)
    ev

// f_updateTFState: consolida la ultima ruptura estructural de escala SWING en el
// snapshot SMC_TFState (bias headline + ultimo BOS y ultimo CHoCH). Es el formato
// PLANO que cruzara request.security al MTF [Sprint 1.4] y alimentara el scoring
// [Sprint 2.1] (los UDT no viajan por security; ver PINE-PLAN §4). Solo entra el
// evento de escala SWING -> una ruptura INTERNA no toca el bias mayor [§1.4]. El
// bias = ev.dir (ya sincronizado con structSwing.bias tras f_detectStructure). ev =
// evento swing (na si no hubo ruptura en la barra). Devuelve el state mutado.
f_updateTFState(SMC_TFState state, SMC_Event ev) =>
    if not na(ev)
        state.bias := ev.dir
        if ev.kind == KIND_BOS
            state.lastBOSPrice := ev.price
            state.lastBOSDir   := ev.dir
            state.lastBOSTime  := ev.barTime
        else if ev.kind == KIND_CHOCH
            state.lastCHoCHPrice := ev.price
            state.lastCHoCHDir   := ev.dir
            state.lastCHoCHTime  := ev.barTime
    state

// --- Order Blocks + mitigacion [reglas-smc-ict §2.1] · T05 ---
// Porta el algoritmo de Order Blocks de LuxAlgo (storeOrdeBlock :502-525,
// deleteOrderBlocks :478-500; v5->v6). El OB es la vela origen del impulso que rompe
// estructura: en ruptura ALCISTA, la vela de MINIMO de la pierna [pivote roto ->
// ruptura]; en BAJISTA, la de MAXIMO. El SWAP high<->low en barras de alta
// volatilidad ((hi-lo) >= highVolFactor*vol) excluye la vela de impulso -> el OB es la
// ultima consolidacion ANTES del impulso. Zona = [low, high] de esa vela (obBounds
// high/low, §2.1). En vez de referencia historica dinamica de series (fragil: RE10045
// fuera de la historia cargada + sin equivalente MQL5), recorre buffers ROLLING de
// barras (bHighs/bLows/bIdxs/bTimes/bVols, que el consumidor puebla cada barra
// confirmada) -> runtime-safe y portable a golden tests MQL5 (ADR-002). Recorre el
// buffer de atras hacia adelante incluyendo barras con originBarIdx <= barIdx <
// ev.barIdx (excluye la barra de ruptura, igual que el slice de LuxAlgo). Solo con
// ruptura CONFIRMADA -> no repinta [§2.1, D-PINE-03]. Devuelve SMC_Zone ZS_ACTIVE o na.
// LIMITE: si originBarIdx (pivote roto) quedo a mas de MAX_BARBUF barras atras, sale del
// buffer rolling y se devuelve na SIN aviso (~21 dias en H1). Replicar el limite en MQL5
// (golden tests, ADR-002); si en Fase 3 estorba, subir MAX_BARBUF o loggear el miss.
f_detectOB(SMC_Event ev, int originBarIdx, array<float> bHighs, array<float> bLows, array<int> bIdxs, array<int> bTimes, array<float> bVols, float highVolFactor, int kind) =>
    SMC_Zone z = na
    if not na(ev) and not na(originBarIdx)
        int n = array.size(bIdxs)
        int   bestPos = na
        float bestVal = na
        if n > 0
            for p = n - 1 to 0
                int bi = array.get(bIdxs, p)
                if bi < originBarIdx
                    break
                if bi < ev.barIdx
                    float hi = array.get(bHighs, p)
                    float lo = array.get(bLows, p)
                    bool hv = (hi - lo) >= (highVolFactor * array.get(bVols, p))
                    if ev.dir == DIR_BULL
                        float pv = hv ? hi : lo
                        if na(bestVal) or pv < bestVal
                            bestVal := pv
                            bestPos := p
                    else
                        float pv = hv ? lo : hi
                        if na(bestVal) or pv > bestVal
                            bestVal := pv
                            bestPos := p
        if not na(bestPos)
            z := SMC_Zone.new(array.get(bHighs, bestPos), array.get(bLows, bestPos), ev.dir, array.get(bIdxs, bestPos), array.get(bTimes, bestPos), ZS_ACTIVE, 0.0, "", kind)
    z

// f_updateZoneMitigation: maquina de estados de mitigacion/invalidacion del UDT
// SMC_Zone [§2.1]. Mas rica que el borrado binario de LuxAlgo (deleteOrderBlocks
// ref :481-500): cuatro estados + mitigatedPct. useClose = fuente (§2.1
// obMitigation): true exige CIERRE dentro; false (HIGHLOW, default) basta la mecha.
// OB ALCISTA (soporte, el precio entra desde arriba): borde cercano = top, borde
// lejano/protector = bottom. PARCIAL si la fuente perfora el top sin llegar al
// bottom (mitigatedPct = (top-src)/altura); MITIGADA si la fuente alcanza el bottom
// (borde lejano, "hizo su trabajo"); INVALIDA si una vela CIERRA bajo el bottom
// (borde protector roto -> candidato a Breaker §Tier2). Bajista simetrico (entra
// desde abajo; protector = top; invalida si close > top). La invalidacion (close)
// tiene prioridad sobre la mitigacion (mecha). ZS_INVALID es terminal; ZS_MITIGATED
// no regresa a PARCIAL (guard state < ZS_MITIGATED) pero puede escalar a INVALID.
// Anti-repaint: llamar dentro de barstate.isconfirmed.
f_updateZoneMitigation(SMC_Zone z, bool useClose) =>
    if z.state != ZS_INVALID
        float height = z.top - z.bottom
        if z.dir == DIR_BULL
            float src = useClose ? close : low
            if close < z.bottom
                z.state := ZS_INVALID
                z.mitigatedPct := 1.0
            else if src <= z.bottom
                z.state := ZS_MITIGATED
                z.mitigatedPct := 1.0
            else if src < z.top
                if z.state < ZS_MITIGATED
                    z.state := ZS_PARTIAL
                z.mitigatedPct := math.max(z.mitigatedPct, height > 0 ? (z.top - src) / height : 0.0)
        else
            float src = useClose ? close : high
            if close > z.top
                z.state := ZS_INVALID
                z.mitigatedPct := 1.0
            else if src >= z.top
                z.state := ZS_MITIGATED
                z.mitigatedPct := 1.0
            else if src > z.bottom
                if z.state < ZS_MITIGATED
                    z.state := ZS_PARTIAL
                z.mitigatedPct := math.max(z.mitigatedPct, height > 0 ? (src - z.bottom) / height : 0.0)
    z

