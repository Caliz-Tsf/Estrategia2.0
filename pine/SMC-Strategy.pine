strategy("SMC Engine — Strategy", overlay = true, initial_capital = 10000, default_qty_type = strategy.percent_of_equity, default_qty_value = 1, commission_type = strategy.commission.cash_per_contract, process_orders_on_close = true)

// === INPUTS ===
// Grupos canonicos (reglas-dev §1.3). Esqueleto: solo inputs base; el resto
// (toggles por concepto, pesos w_* del scoring) llega en sus tareas.
GRP_STRUCT = "Estructura"
GRP_SCORE  = "Scoring"
i_swingLen    = input.int(5, "Swing length",    minval = 2, group = GRP_STRUCT)
i_internalLen = input.int(3, "Internal length", minval = 1, group = GRP_STRUCT)
i_scoreThresh = input.int(0, "Score threshold (calibrar Fase 3)", group = GRP_SCORE)

// === LIBRARY CORE ===
// ---------------------------------------------------------------------------
// Nucleo de deteccion SMC/ICT. BYTE-IDENTICO en SMC-Visual y SMC-Strategy
// (lo vigila scripts/check-core-sync.ps1 — regla dura #2). El core NO dibuja y
// NO llama request.security(): solo tipos, constantes y funciones puras
// (entradas -> detecciones). La version exportable equivalente vive en
// SMC-Library.pine [D-PINE-01]. Esqueleto F1-S1.1-T01: tipos + constantes +
// arrays acotados; las f_detect*/f_compute* se añaden en T02+.
// ---------------------------------------------------------------------------
// Constantes 'kind' por categoria [reglas-dev §1.2 · PINE-PLAN §2]
KIND_OB          = 1
KIND_FVG         = 2
KIND_BREAKER     = 3
KIND_REJECTION   = 4
KIND_MITIGATION  = 5
KIND_OTE         = 6
KIND_GP          = 7
KIND_BOS          = 20
KIND_CHOCH        = 21
KIND_MSS          = 22
KIND_SWEEP        = 23
KIND_GRAB         = 24
KIND_JUDAS        = 25
KIND_DISPLACEMENT = 26
KIND_IDM          = 27
KIND_EMACROSS     = 28
KIND_EMABOUNCE    = 29
KIND_FLIP         = 30
KIND_HH = 40
KIND_HL = 41
KIND_LH = 42
KIND_LL = 43
DIR_BULL     = 1
DIR_BEAR     = -1
ZS_ACTIVE    = 0
ZS_PARTIAL   = 1
ZS_MITIGATED = 2
ZS_INVALID   = 3
MAX_ZONES  = 50
MAX_EVENTS = 100
MAX_SWINGS = 100
MAX_POOLS  = 50
type SMC_Zone
    float  top
    float  bottom
    int    dir
    int    barIdx
    int    barTime
    int    state        = 0
    float  mitigatedPct = 0.0
    string tf           = ""
    int    kind         = 0
type SMC_Event
    float  price
    int    dir
    int    barIdx
    int    barTime
    string tf   = ""
    int    kind = 0
type SMC_Swing
    float  price
    int    barIdx
    int    barTime
    int    kind   = 0
    bool   swept  = false
    bool   isHigh = false
type SMC_Pool
    float  level
    int    dir
    int    touches  = 1
    int    barTime
    bool   swept    = false
    string tf       = ""
type SMC_TFState
    int    bias           = 0
    float  lastBOSPrice   = na
    int    lastBOSDir     = 0
    int    lastBOSTime    = 0
    float  lastCHoCHPrice = na
    int    lastCHoCHDir   = 0
    int    lastCHoCHTime  = 0
    float  pdHigh         = na
    float  pdLow          = na
    float  ema20          = na
    float  ema50          = na
    float  ema200         = na
f_pushZone(array<SMC_Zone> a, SMC_Zone z, int maxN) =>
    array.push(a, z)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushEvent(array<SMC_Event> a, SMC_Event e, int maxN) =>
    array.push(a, e)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushSwing(array<SMC_Swing> a, SMC_Swing s, int maxN) =>
    array.push(a, s)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushPool(array<SMC_Pool> a, SMC_Pool p, int maxN) =>
    array.push(a, p)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)

// --- Deteccion de swings estructurales [reglas-smc-ict §1.1] ---
// Pivote ESTRICTO: la barra 'len' atras es swing high si su high supera (>) el
// high de las 'len' barras a cada lado; swing low si su low es menor (<).
// Igualdad a cualquier lado => NO es swing (candidato EQH/EQL). Espejo exacto
// del detector golden scripts/ver05/detect.py:pivots (ADR-002). Anti-repaint:
// el llamador evalua bajo barstate.isconfirmed; el swing NACE 'len' barras
// atras (latencia inherente = len, deseable) y sus coords son las de esa barra
// central. Polaridad en isHigh; el kind (HH/HL/LH/LL) lo pone f_classifySwing.
// Devuelve SMC_Swing nuevo o na (un centro no puede ser high y low a la vez).
f_detectSwings(int len) =>
    SMC_Swing s = na
    bool isH = not na(high[len])
    bool isL = not na(low[len])
    float ch = high[len]
    float cl = low[len]
    for k = 1 to len
        if na(high[len + k]) or na(high[len - k]) or ch <= high[len + k] or ch <= high[len - k]
            isH := false
        if na(low[len + k]) or na(low[len - k]) or cl >= low[len + k] or cl >= low[len - k]
            isL := false
    if isH
        s := SMC_Swing.new(price = high[len], barIdx = bar_index[len], barTime = time[len], isHigh = true)
    else if isL
        s := SMC_Swing.new(price = low[len], barIdx = bar_index[len], barTime = time[len], isHigh = false)
    s

// --- Clasificacion HH/HL/LH/LL [reglas-smc-ict §1.2] ---
// Compara el swing recien confirmado con el PREVIO DEL MISMO TIPO (high vs
// high, low vs low) recorriendo prevSwings de atras hacia delante. HH/LH para
// highs, HL/LL para lows. Sin previo del mismo tipo o igualdad exacta => 0 (no
// reclasifica; candidato EQH/EQL, como 'H?'/'EQ-H' del golden detect.py). La
// polaridad vive en swing.isHigh, no en el kind devuelto.
f_classifySwing(SMC_Swing swing, array<SMC_Swing> prevSwings) =>
    int kind = 0
    if not na(swing)
        float prevPrice = na
        int n = array.size(prevSwings)
        if n > 0
            for i = n - 1 to 0
                SMC_Swing p = array.get(prevSwings, i)
                if p.isHigh == swing.isHigh
                    prevPrice := p.price
                    break
        if not na(prevPrice)
            if swing.isHigh
                kind := swing.price > prevPrice ? KIND_HH : swing.price < prevPrice ? KIND_LH : 0
            else
                kind := swing.price > prevPrice ? KIND_HL : swing.price < prevPrice ? KIND_LL : 0
    kind

// === DETECCIÓN TF PROPIO ===
// Estado global del chart actual. Arrays con prefijo SMC_ [PINE-PLAN §2].
var array<SMC_Swing> SMC_swings = array.new<SMC_Swing>()
var array<SMC_Event> SMC_events = array.new<SMC_Event>()
var array<SMC_Zone>  SMC_zones  = array.new<SMC_Zone>()
var array<SMC_Pool>  SMC_pools  = array.new<SMC_Pool>()

// Swings estructurales (escala swingLen). Solo en barra confirmada [D-PINE-03].
// Identico a la deteccion de Visual: el swing nace i_swingLen barras atras, se
// clasifica contra los ya confirmados y se apila FIFO. La Strategy no dibuja;
// estos swings alimentaran el scoring (Sprint 2.1). BOS/CHoCH interno en T03.
if barstate.isconfirmed
    SMC_Swing s = f_detectSwings(i_swingLen)
    if not na(s)
        s.kind := f_classifySwing(s, SMC_swings)
        f_pushSwing(SMC_swings, s, MAX_SWINGS)

// === MTF ===
// request.security D1/H1 (max 2 en Strategy). Pendiente Sprint 1.4 (T13).

// === SCORING ===
// f_scoreConfluences -> scoreLong/scoreShort (42 confluencias canonicas,
// WORKPLAN §4.8). Pendiente Sprint 2.1.

// === ENTRADAS/SALIDAS ===
// strategy.entry/exit + trailing estructural + filtros duros (R:R >= 3,
// sin posicion del mismo lado). Pendiente Sprint 2.1.

// === PANEL ===
// Esqueleto: label de estado que confirma que el core carga y reporta el
// tamaño de los arrays globales. Tabla "ultimas señales" llega en Sprint 2.x.
// barstate.islastconfirmedhistory (no islast): en una strategy sin
// calc_on_every_tick, islast avisa por barra en tiempo real -> usar la ultima
// barra historica confirmada evita el warning y respeta el anti-repaint.
if barstate.islastconfirmedhistory
    var label lbl = na
    label.delete(lbl)
    lbl := label.new(bar_index, high, "SMC Strategy — T02 swings\nswings=" + str.tostring(array.size(SMC_swings)) + "  eventos=" + str.tostring(array.size(SMC_events)) + "  zonas=" + str.tostring(array.size(SMC_zones)) + "  pools=" + str.tostring(array.size(SMC_pools)), style = label.style_label_down, color = color.new(color.blue, 0), textcolor = color.white)

// === ALERTAS ===
// alert_message JSON por entrada (plantilla PINE-PLAN §5). Pendiente Sprint 2.1.
