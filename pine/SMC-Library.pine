library("SMC_Library", overlay = true)

// --- Constantes 'kind' por categoria [reglas-dev §1.2 · PINE-PLAN §2] ---
// Zonas (SMC_Zone.kind)
export const int KIND_OB          = 1
export const int KIND_FVG         = 2
export const int KIND_BREAKER     = 3
export const int KIND_REJECTION   = 4
export const int KIND_MITIGATION  = 5
export const int KIND_OTE         = 6
export const int KIND_GP          = 7
// Eventos (SMC_Event.kind)
export const int KIND_BOS          = 20
export const int KIND_CHOCH        = 21
export const int KIND_MSS          = 22
export const int KIND_SWEEP        = 23
export const int KIND_GRAB         = 24
export const int KIND_JUDAS        = 25
export const int KIND_DISPLACEMENT = 26
export const int KIND_IDM          = 27
export const int KIND_EMACROSS     = 28
export const int KIND_EMABOUNCE    = 29
export const int KIND_FLIP         = 30
// Swings (SMC_Swing.kind)
export const int KIND_HH = 40
export const int KIND_HL = 41
export const int KIND_LH = 42
export const int KIND_LL = 43

// --- Direccion canonica y estados de zona ---
export const int DIR_BULL     = 1
export const int DIR_BEAR     = -1
export const int ZS_ACTIVE    = 0
export const int ZS_PARTIAL   = 1
export const int ZS_MITIGATED = 2
export const int ZS_INVALID   = 3

// --- Limites de arrays por TF (performance, reglas-dev §1.6) ---
export const int MAX_ZONES  = 50
export const int MAX_EVENTS = 100
export const int MAX_SWINGS = 100
export const int MAX_POOLS  = 50
export const int MAX_BARBUF = 500

// --- UDTs (PINE-PLAN §2) ---
// Zona con extension espacial (OB, FVG, Breaker, Rejection, OTE, Premium/Discount...)
export type SMC_Zone
    float  top
    float  bottom
    int    dir
    int    barIdx
    int    barTime
    int    state        = 0
    float  mitigatedPct = 0.0
    string tf           = ""
    int    kind         = 0

// Evento puntual (BOS, CHoCH, MSS, Sweep, Judas, Displacement, IDM, EMA cross/bounce...)
export type SMC_Event
    float  price
    int    dir
    int    barIdx
    int    barTime
    string tf   = ""
    int    kind = 0

// Punto de swing estructural
export type SMC_Swing
    float  price
    int    barIdx
    int    barTime
    int    kind  = 0
    bool   swept = false

// Pool de liquidez (EQH/EQL clusterizados)
export type SMC_Pool
    float  level
    int    dir
    int    touches  = 1
    int    barTime
    bool   swept    = false
    string tf       = ""

// Snapshot de estado por timeframe (campos planos: lo que cruza request.security)
export type SMC_TFState
    int    bias           = 0
    float  lastBOSPrice   = na
    int    lastBOSDir     = 0
    int    lastBOSTime    = 0
    float  lastCHoCHPrice = na
    int    lastCHoCHDir   = 0
    int    lastCHoCHTime  = 0
    float  pdHigh         = na
    float  pdLow          = na
    float  ema20          = na
    float  ema50          = na
    float  ema200         = na

// --- Helpers de arrays acotados [reglas-dev §1.6] ---
// Tras cada push, si se supera el limite se descarta el mas antiguo (FIFO).
export f_pushZone(array<SMC_Zone> a, SMC_Zone z, int maxN) =>
    array.push(a, z)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)

export f_pushEvent(array<SMC_Event> a, SMC_Event e, int maxN) =>
    array.push(a, e)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)

export f_pushSwing(array<SMC_Swing> a, SMC_Swing s, int maxN) =>
    array.push(a, s)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)

export f_pushPool(array<SMC_Pool> a, SMC_Pool p, int maxN) =>
    array.push(a, p)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)

// --- Swings + clasificacion HH/HL/LH/LL [reglas-smc-ict §1.1/§1.2] · T02 ---
// f_detectSwings: pivote simetrico estricto. high[len] > high de las len velas a
// cada lado (low simetrico). Equivale a ta.pivothigh/low(len, len). Confirmado al
// cierre de la vela t+len -> latencia len velas, cero repaint [§1.1]. Devuelve
// [precioHigh, precioLow] del pivote centrado len velas atras; na si no hay.
export f_detectSwings(int len) =>
    [ta.pivothigh(len, len), ta.pivotlow(len, len)]

// f_classifySwing: etiqueta el swing recien confirmado contra el swing previo del
// MISMO tipo (high vs high, low vs low) [§1.2]. isHigh = true si es swing high.
// Recorre los swings almacenados de atras hacia adelante hasta el ultimo del mismo
// tipo. Igualdad exacta de precio: no reclasifica -> hereda el kind previo
// (candidato EQH/EQL). Primer swing del tipo (sin referencia): seed HH/LL.
// INVARIANTE [T02 · obs. validador 97/100]: la clasificacion filtra por tipo
// (sHigh == isHigh), asi que un swing high y un swing low confirmados en la MISMA
// vela t (caso spike, casi imposible con swingLen=5 en H1) se etiquetan de forma
// independiente y NO interfieren. No se asume alternancia high/low aguas abajo:
// BOS/CHoCH/MSS/EQH/EQL leen por tipo. Anotado para revision Fable pre-Fase 4
// (docs/notas-revision-fable.md) por paridad MQL5 (golden tests, ADR-002).
export f_classifySwing(bool isHigh, float price, array<SMC_Swing> swings) =>
    int   prevKind  = na
    float prevPrice = na
    if array.size(swings) > 0
        for i = array.size(swings) - 1 to 0
            SMC_Swing s = array.get(swings, i)
            bool sHigh = s.kind == KIND_HH or s.kind == KIND_LH
            if sHigh == isHigh
                prevKind  := s.kind
                prevPrice := s.price
                break
    int kind = na
    if isHigh
        kind := na(prevPrice) ? KIND_HH : price > prevPrice ? KIND_HH : price < prevPrice ? KIND_LH : prevKind
    else
        kind := na(prevPrice) ? KIND_LL : price > prevPrice ? KIND_HL : price < prevPrice ? KIND_LL : prevKind
    kind

// --- Estructura de mercado: BOS / CHoCH [reglas-smc-ict §1.3/§1.4] · T03 ---
// Modelo de bias estructural: por escala se mantiene el ultimo swing high y low
// confirmados (highLevel/lowLevel) con flag 'crossed' (evita re-disparo sobre el
// mismo nivel) y un 'bias' (+1/-1) fijado por la ultima ruptura. BOS vs CHoCH lo da
// el bias vigente al romper [§1.3/§1.4]: romper el nivel que EXTIENDE -> BOS; el que
// PROTEGE -> CHoCH. Ruptura por CIERRE estricto (no mecha); el flag 'crossed' replica
// el oraculo de paridad scripts/ver05/detect.py (ADR-002) y LuxAlgo displayStructure
// (:551-612, v5->v6). Anti-repaint [D-PINE-03] via barstate.isconfirmed en el consumidor.
export type SMC_Structure
    float highLevel   = na
    int   highBarIdx  = na
    int   highTime    = na
    bool  highCrossed = false
    float lowLevel    = na
    int   lowBarIdx   = na
    int   lowTime     = na
    bool  lowCrossed  = false
    int   bias        = 0

// Fija un swing confirmado como nivel estructural vigente y resetea 'crossed'.
export f_setStructureHigh(SMC_Structure st, float price, int barIdx, int barTime) =>
    st.highLevel   := price
    st.highBarIdx  := barIdx
    st.highTime    := barTime
    st.highCrossed := false

export f_setStructureLow(SMC_Structure st, float price, int barIdx, int barTime) =>
    st.lowLevel   := price
    st.lowBarIdx  := barIdx
    st.lowTime    := barTime
    st.lowCrossed := false

// Evalua ruptura por cierre del nivel vigente; muta estado (crossed+bias) y devuelve
// el SMC_Event (na si no hay). okHigh/okLow = guard de nivel-distinto del interno.
export f_detectStructure(SMC_Structure st, int breakBarIdx, int breakTime, bool okHigh, bool okLow) =>
    SMC_Event ev = na
    if okHigh and not na(st.highLevel) and not st.highCrossed and close > st.highLevel
        int tag = st.bias == DIR_BEAR ? KIND_CHOCH : KIND_BOS
        st.highCrossed := true
        st.bias        := DIR_BULL
        ev := SMC_Event.new(st.highLevel, DIR_BULL, breakBarIdx, breakTime, "", tag)
    else if okLow and not na(st.lowLevel) and not st.lowCrossed and close < st.lowLevel
        int tag = st.bias == DIR_BULL ? KIND_CHOCH : KIND_BOS
        st.lowCrossed := true
        st.bias        := DIR_BEAR
        ev := SMC_Event.new(st.lowLevel, DIR_BEAR, breakBarIdx, breakTime, "", tag)
    ev

// Consolida la ultima ruptura SWING en el snapshot plano SMC_TFState (bias + ultimo
// BOS/CHoCH): lo que cruza request.security al MTF y alimenta el scoring. Solo el
// evento swing -> la ruptura interna no voltea el bias mayor [§1.4].
export f_updateTFState(SMC_TFState state, SMC_Event ev) =>
    if not na(ev)
        state.bias := ev.dir
        if ev.kind == KIND_BOS
            state.lastBOSPrice := ev.price
            state.lastBOSDir   := ev.dir
            state.lastBOSTime  := ev.barTime
        else if ev.kind == KIND_CHOCH
            state.lastCHoCHPrice := ev.price
            state.lastCHoCHDir   := ev.dir
            state.lastCHoCHTime  := ev.barTime
    state

// --- Order Blocks + mitigacion [reglas-smc-ict §2.1] · T05 ---
// f_detectOB: porta el algoritmo OB de LuxAlgo (storeOrdeBlock :502-525,
// deleteOrderBlocks :478-500; v5->v6). El OB es la vela origen del impulso que rompe
// estructura: en ruptura ALCISTA, la vela de MINIMO de la pierna [pivote roto ->
// ruptura]; en BAJISTA, la de MAXIMO. El SWAP high<->low en barras de alta volatilidad
// ((hi-lo) >= highVolFactor*vol) excluye la vela de impulso -> el OB es la ultima
// consolidacion ANTES del impulso. Zona = [low, high] de esa vela (obBounds high/low).
// En vez de referencia historica dinamica de series (fragil: RE10045 fuera de historia
// + sin equivalente MQL5), recorre buffers ROLLING de barras (que el consumidor puebla
// cada barra confirmada) -> runtime-safe y portable a golden tests MQL5 (ADR-002).
// Recorre el buffer incluyendo barras con originBarIdx <= barIdx < ev.barIdx (excluye
// la barra de ruptura, igual que el slice de LuxAlgo). Solo con ruptura CONFIRMADA ->
// no repinta [§2.1, D-PINE-03]. Devuelve SMC_Zone ZS_ACTIVE o na.
// LIMITE: si originBarIdx (pivote roto) quedo a mas de MAX_BARBUF barras atras, sale del
// buffer rolling y se devuelve na SIN aviso (~21 dias en H1). Replicar el limite en MQL5
// (golden tests, ADR-002); si en Fase 3 estorba, subir MAX_BARBUF o loggear el miss.
export f_detectOB(SMC_Event ev, int originBarIdx, array<float> bHighs, array<float> bLows, array<int> bIdxs, array<int> bTimes, array<float> bVols, float highVolFactor, int kind) =>
    SMC_Zone z = na
    if not na(ev) and not na(originBarIdx)
        int n = array.size(bIdxs)
        int   bestPos = na
        float bestVal = na
        if n > 0
            for p = n - 1 to 0
                int bi = array.get(bIdxs, p)
                if bi < originBarIdx
                    break
                if bi < ev.barIdx
                    float hi = array.get(bHighs, p)
                    float lo = array.get(bLows, p)
                    bool hv = (hi - lo) >= (highVolFactor * array.get(bVols, p))
                    if ev.dir == DIR_BULL
                        float pv = hv ? hi : lo
                        if na(bestVal) or pv < bestVal
                            bestVal := pv
                            bestPos := p
                    else
                        float pv = hv ? lo : hi
                        if na(bestVal) or pv > bestVal
                            bestVal := pv
                            bestPos := p
        if not na(bestPos)
            z := SMC_Zone.new(array.get(bHighs, bestPos), array.get(bLows, bestPos), ev.dir, array.get(bIdxs, bestPos), array.get(bTimes, bestPos), ZS_ACTIVE, 0.0, "", kind)
    z

// f_updateZoneMitigation: maquina de estados de mitigacion/invalidacion del UDT
// SMC_Zone [§2.1] (mas rica que el borrado binario de LuxAlgo). useClose = fuente
// (§2.1 obMitigation): true exige cierre dentro; false (HIGHLOW) basta la mecha. OB
// alcista (soporte): cercano = top, lejano/protector = bottom. PARCIAL si la fuente
// perfora el top sin llegar al bottom; MITIGADA al alcanzar el bottom; INVALIDA si
// una vela CIERRA bajo el bottom (-> Breaker §Tier2). Bajista simetrico. Invalidacion
// (close) prioritaria. ZS_INVALID terminal; ZS_MITIGATED no regresa a PARCIAL.
export f_updateZoneMitigation(SMC_Zone z, bool useClose) =>
    if z.state != ZS_INVALID
        float height = z.top - z.bottom
        if z.dir == DIR_BULL
            float src = useClose ? close : low
            if close < z.bottom
                z.state := ZS_INVALID
                z.mitigatedPct := 1.0
            else if src <= z.bottom
                z.state := ZS_MITIGATED
                z.mitigatedPct := 1.0
            else if src < z.top
                if z.state < ZS_MITIGATED
                    z.state := ZS_PARTIAL
                z.mitigatedPct := math.max(z.mitigatedPct, height > 0 ? (z.top - src) / height : 0.0)
        else
            float src = useClose ? close : high
            if close > z.top
                z.state := ZS_INVALID
                z.mitigatedPct := 1.0
            else if src >= z.top
                z.state := ZS_MITIGATED
                z.mitigatedPct := 1.0
            else if src > z.bottom
                if z.state < ZS_MITIGATED
                    z.state := ZS_PARTIAL
                z.mitigatedPct := math.max(z.mitigatedPct, height > 0 ? (src - z.bottom) / height : 0.0)
    z
