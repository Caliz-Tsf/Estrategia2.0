indicator("SMC Engine — Visual", overlay = true, max_labels_count = 500, max_lines_count = 500, max_boxes_count = 500)

// === INPUTS ===
// Grupos canonicos (reglas-dev §1.3). Esqueleto: solo toggles base; cada
// concepto añade su grupo en su tarea (T02+).
GRP_STRUCT = "Estructura"
GRP_PANEL  = "Panel"
i_showPanel   = input.bool(true, "Mostrar panel de estado", group = GRP_PANEL)
i_swingLen    = input.int(5, "Swing length",    minval = 2, group = GRP_STRUCT)
i_internalLen = input.int(3, "Internal length", minval = 1, group = GRP_STRUCT)
i_showSwings  = input.bool(true, "Mostrar swings (HH/HL/LH/LL)", group = GRP_STRUCT)
i_showStruct  = input.bool(true,  "Mostrar BOS/CHoCH (swing)",   group = GRP_STRUCT)
i_showInternal = input.bool(false, "Mostrar BOS/CHoCH interno",  group = GRP_STRUCT)

// === LIBRARY CORE ===
// ---------------------------------------------------------------------------
// Nucleo de deteccion SMC/ICT. BYTE-IDENTICO en SMC-Visual y SMC-Strategy
// (lo vigila scripts/check-core-sync.ps1 — regla dura #2). El core NO dibuja y
// NO llama request.security(): solo tipos, constantes y funciones puras
// (entradas -> detecciones). La version exportable equivalente vive en
// SMC-Library.pine [D-PINE-01]. Esqueleto F1-S1.1-T01: tipos + constantes +
// arrays acotados; las f_detect*/f_compute* se añaden en T02+.
// ---------------------------------------------------------------------------
// Constantes 'kind' por categoria [reglas-dev §1.2 · PINE-PLAN §2]
KIND_OB          = 1
KIND_FVG         = 2
KIND_BREAKER     = 3
KIND_REJECTION   = 4
KIND_MITIGATION  = 5
KIND_OTE         = 6
KIND_GP          = 7
KIND_BOS          = 20
KIND_CHOCH        = 21
KIND_MSS          = 22
KIND_SWEEP        = 23
KIND_GRAB         = 24
KIND_JUDAS        = 25
KIND_DISPLACEMENT = 26
KIND_IDM          = 27
KIND_EMACROSS     = 28
KIND_EMABOUNCE    = 29
KIND_FLIP         = 30
KIND_HH = 40
KIND_HL = 41
KIND_LH = 42
KIND_LL = 43
DIR_BULL     = 1
DIR_BEAR     = -1
ZS_ACTIVE    = 0
ZS_PARTIAL   = 1
ZS_MITIGATED = 2
ZS_INVALID   = 3
MAX_ZONES  = 50
MAX_EVENTS = 100
MAX_SWINGS = 100
MAX_POOLS  = 50
type SMC_Zone
    float  top
    float  bottom
    int    dir
    int    barIdx
    int    barTime
    int    state        = 0
    float  mitigatedPct = 0.0
    string tf           = ""
    int    kind         = 0
type SMC_Event
    float  price
    int    dir
    int    barIdx
    int    barTime
    string tf   = ""
    int    kind = 0
type SMC_Swing
    float  price
    int    barIdx
    int    barTime
    int    kind  = 0
    bool   swept = false
type SMC_Pool
    float  level
    int    dir
    int    touches  = 1
    int    barTime
    bool   swept    = false
    string tf       = ""
type SMC_TFState
    int    bias           = 0
    float  lastBOSPrice   = na
    int    lastBOSDir     = 0
    int    lastBOSTime    = 0
    float  lastCHoCHPrice = na
    int    lastCHoCHDir   = 0
    int    lastCHoCHTime  = 0
    float  pdHigh         = na
    float  pdLow          = na
    float  ema20          = na
    float  ema50          = na
    float  ema200         = na
f_pushZone(array<SMC_Zone> a, SMC_Zone z, int maxN) =>
    array.push(a, z)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushEvent(array<SMC_Event> a, SMC_Event e, int maxN) =>
    array.push(a, e)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushSwing(array<SMC_Swing> a, SMC_Swing s, int maxN) =>
    array.push(a, s)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushPool(array<SMC_Pool> a, SMC_Pool p, int maxN) =>
    array.push(a, p)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)

// --- Swings + clasificacion HH/HL/LH/LL [reglas-smc-ict §1.1/§1.2] · T02 ---
// f_detectSwings: pivote simetrico estricto. high[len] > high de las len velas a
// cada lado (low simetrico). Equivale a ta.pivothigh/low(len, len). Confirmado al
// cierre de la vela t+len -> latencia len velas, cero repaint [§1.1]. Devuelve
// [precioHigh, precioLow] del pivote centrado len velas atras; na si no hay.
f_detectSwings(int len) =>
    [ta.pivothigh(len, len), ta.pivotlow(len, len)]

// f_classifySwing: etiqueta el swing recien confirmado contra el swing previo del
// MISMO tipo (high vs high, low vs low) [§1.2]. isHigh = true si es swing high.
// Recorre los swings almacenados de atras hacia adelante hasta el ultimo del mismo
// tipo. Igualdad exacta de precio: no reclasifica -> hereda el kind previo
// (candidato EQH/EQL). Primer swing del tipo (sin referencia): seed HH/LL.
// INVARIANTE [T02 · obs. validador 97/100]: la clasificacion filtra por tipo
// (sHigh == isHigh), asi que un swing high y un swing low confirmados en la MISMA
// vela t (caso spike, casi imposible con swingLen=5 en H1) se etiquetan de forma
// independiente y NO interfieren. No se asume alternancia high/low aguas abajo:
// BOS/CHoCH/MSS/EQH/EQL leen por tipo. Anotado para revision Fable pre-Fase 4
// (docs/notas-revision-fable.md) por paridad MQL5 (golden tests, ADR-002).
f_classifySwing(bool isHigh, float price, array<SMC_Swing> swings) =>
    int   prevKind  = na
    float prevPrice = na
    if array.size(swings) > 0
        for i = array.size(swings) - 1 to 0
            SMC_Swing s = array.get(swings, i)
            bool sHigh = s.kind == KIND_HH or s.kind == KIND_LH
            if sHigh == isHigh
                prevKind  := s.kind
                prevPrice := s.price
                break
    int kind = na
    if isHigh
        kind := na(prevPrice) ? KIND_HH : price > prevPrice ? KIND_HH : price < prevPrice ? KIND_LH : prevKind
    else
        kind := na(prevPrice) ? KIND_LL : price > prevPrice ? KIND_HL : price < prevPrice ? KIND_LL : prevKind
    kind

// --- Estructura de mercado: BOS / CHoCH [reglas-smc-ict §1.3/§1.4] · T03 ---
// Modelo de bias estructural (reglas, seccion "Modelo de bias estructural"): por
// escala se mantiene el ultimo swing high y el ultimo swing low confirmados
// (highLevel/lowLevel) con un flag 'crossed' que evita re-disparar sobre el mismo
// nivel, y un 'bias' (+1/-1) fijado por la ultima ruptura. La distincion BOS vs
// CHoCH la da el bias vigente al romper [reglas §1.3/§1.4]:
//   - close rompe el nivel que EXTIENDE la tendencia -> BOS  (continuacion).
//   - close rompe el nivel que PROTEGE  la tendencia -> CHoCH (cambio de caracter).
// Ruptura por CIERRE estricto (close > highLevel / close < lowLevel), NO por mecha
// [§1.3]; el flag 'crossed' replica el 'topBroken/btmBroken' del oraculo de paridad
// scripts/ver05/detect.py (ADR-002) y el 'pivot.crossed' de LuxAlgo displayStructure
// (ref :551-612, v5->v6). El guard barstate.isconfirmed (en DETECCION) hace que el
// cierre que rompe sea definitivo -> anti-repaint [D-PINE-03]. Escala swing
// (swingLen) y escala interna (internalLen) se trackean en SMC_Structure separados;
// el bias mayor es el de la escala swing: una ruptura INTERNA no voltea el bias swing
// [§1.4]. okHigh/okLow permiten el guard de nivel-distinto del interno (no duplicar
// la senal swing cuando el pivote interno coincide, cf. LuxAlgo extraCondition
// internalHigh.currentLevel != swingHigh.currentLevel).
type SMC_Structure
    float highLevel   = na
    int   highBarIdx  = na
    int   highTime    = na
    bool  highCrossed = false
    float lowLevel    = na
    int   lowBarIdx   = na
    int   lowTime     = na
    bool  lowCrossed  = false
    int   bias        = 0

// f_setStructureHigh/Low: fija un swing recien confirmado como nivel estructural
// vigente y resetea 'crossed' (nivel fresco, aun no roto). Por construccion del
// pivote, el close de la barra de confirmacion nunca rompe el nivel recien fijado.
f_setStructureHigh(SMC_Structure st, float price, int barIdx, int barTime) =>
    st.highLevel   := price
    st.highBarIdx  := barIdx
    st.highTime    := barTime
    st.highCrossed := false

f_setStructureLow(SMC_Structure st, float price, int barIdx, int barTime) =>
    st.lowLevel   := price
    st.lowBarIdx  := barIdx
    st.lowTime    := barTime
    st.lowCrossed := false

// f_detectStructure: evalua ruptura por cierre del nivel estructural vigente y, si
// hay, muta el estado (crossed + bias) y devuelve el SMC_Event (na si no hay).
// Prioriza el lado alcista (else-if): un mismo close no puede superar el highLevel y
// perforar el lowLevel salvo niveles invertidos, caso que no ocurre con estructura
// sana; el oraculo ver05 usa dos if separados y produce la misma lista en la ventana
// validada. price = nivel roto; barIdx/barTime = barra de ruptura; kind = BOS|CHoCH.
f_detectStructure(SMC_Structure st, int breakBarIdx, int breakTime, bool okHigh, bool okLow) =>
    SMC_Event ev = na
    if okHigh and not na(st.highLevel) and not st.highCrossed and close > st.highLevel
        int tag = st.bias == DIR_BEAR ? KIND_CHOCH : KIND_BOS
        st.highCrossed := true
        st.bias        := DIR_BULL
        ev := SMC_Event.new(st.highLevel, DIR_BULL, breakBarIdx, breakTime, "", tag)
    else if okLow and not na(st.lowLevel) and not st.lowCrossed and close < st.lowLevel
        int tag = st.bias == DIR_BULL ? KIND_CHOCH : KIND_BOS
        st.lowCrossed := true
        st.bias        := DIR_BEAR
        ev := SMC_Event.new(st.lowLevel, DIR_BEAR, breakBarIdx, breakTime, "", tag)
    ev

// === DETECCIÓN TF PROPIO ===
// Estado global del chart actual. Arrays con prefijo SMC_ [PINE-PLAN §2].
// Las detecciones que los pueblan llegan en T02+ (swings, BOS/CHoCH, ...).
var array<SMC_Swing> SMC_swings = array.new<SMC_Swing>()
var array<SMC_Event> SMC_events = array.new<SMC_Event>()
var array<SMC_Zone>  SMC_zones  = array.new<SMC_Zone>()
var array<SMC_Pool>  SMC_pools  = array.new<SMC_Pool>()

// --- Swings [T02] ---
// pivothigh/low(len,len) recien confirma len velas tras el pivote -> el guard
// barstate.isconfirmed evita actuar sobre la vela en formacion (anti-repaint
// [§1.1]). El swing pertenece a la vela t = bar_index - len; clasificar ANTES de
// hacer push (f_classifySwing lee el swing previo del mismo tipo ya almacenado).
[swingHigh, swingLow] = f_detectSwings(i_swingLen)
newSwingHigh = barstate.isconfirmed and not na(swingHigh)
newSwingLow  = barstate.isconfirmed and not na(swingLow)
int swingHighKind = na
int swingLowKind  = na
if newSwingHigh
    swingHighKind := f_classifySwing(true, swingHigh, SMC_swings)
    f_pushSwing(SMC_swings, SMC_Swing.new(swingHigh, bar_index - i_swingLen, time[i_swingLen], swingHighKind, false), MAX_SWINGS)
if newSwingLow
    swingLowKind := f_classifySwing(false, swingLow, SMC_swings)
    f_pushSwing(SMC_swings, SMC_Swing.new(swingLow, bar_index - i_swingLen, time[i_swingLen], swingLowKind, false), MAX_SWINGS)

// --- Estructura BOS/CHoCH [T03] ---
// Estado estructural persistente por escala. structSwing = bias mayor (headline);
// structInternal = estructura fina (internalLen), no voltea el bias swing [§1.4].
var SMC_Structure structSwing    = SMC_Structure.new()
var SMC_Structure structInternal = SMC_Structure.new()

// Pivotes internos (los swing ya se calcularon arriba). Mismo guard anti-repaint.
[internalHigh, internalLow] = f_detectSwings(i_internalLen)
newInternalHigh = barstate.isconfirmed and not na(internalHigh)
newInternalLow  = barstate.isconfirmed and not na(internalLow)

// Fijar el swing recien confirmado como nivel estructural vigente (anclado a t).
if newSwingHigh
    f_setStructureHigh(structSwing, swingHigh, bar_index - i_swingLen, time[i_swingLen])
if newSwingLow
    f_setStructureLow(structSwing, swingLow, bar_index - i_swingLen, time[i_swingLen])
if newInternalHigh
    f_setStructureHigh(structInternal, internalHigh, bar_index - i_internalLen, time[i_internalLen])
if newInternalLow
    f_setStructureLow(structInternal, internalLow, bar_index - i_internalLen, time[i_internalLen])

// Ruptura estructural solo al cierre confirmado (anti-repaint [D-PINE-03]). El
// interno usa guard de nivel-distinto: no duplica la senal cuando su pivote coincide
// con el del swing (cf. LuxAlgo extraCondition).
SMC_Event evStructSwing = na
SMC_Event evStructInt   = na
if barstate.isconfirmed
    evStructSwing := f_detectStructure(structSwing, bar_index, time, true, true)
    bool okIntHigh = structInternal.highLevel != structSwing.highLevel
    bool okIntLow  = structInternal.lowLevel  != structSwing.lowLevel
    evStructInt   := f_detectStructure(structInternal, bar_index, time, okIntHigh, okIntLow)
    if not na(evStructSwing)
        f_pushEvent(SMC_events, evStructSwing, MAX_EVENTS)
    if not na(evStructInt)
        f_pushEvent(SMC_events, evStructInt, MAX_EVENTS)

// === MTF ===
// request.security D1/H1 (max 4 en Visual). Pendiente Sprint 1.4 (T13).

// === DIBUJO ===
// f_draw<Concepto>() por concepto, cada uno con su cuota de objetos [PINE-PLAN §5].
// f_drawSwing: etiqueta flotante HH/HL/LH/LL en la vela del pivote. Estructura
// alcista (HH/HL) en verde-azulado, bajista (LH/LL) en rojo. style_label_down
// sobre swing highs (texto colgando bajo el techo), style_label_up bajo lows.
f_drawSwing(int barIdx, float price, int kind) =>
    bool isHigh = kind == KIND_HH or kind == KIND_LH
    [txt, col] = switch kind
        KIND_HH => ["HH", color.teal]
        KIND_HL => ["HL", color.teal]
        KIND_LH => ["LH", color.red]
        KIND_LL => ["LL", color.red]
        => ["?", color.gray]
    label.new(barIdx, price, txt, style = isHigh ? label.style_label_down : label.style_label_up, color = color.new(color.gray, 100), textcolor = col, size = size.small)

// f_drawStructure: linea del nivel roto (origen pivote -> barra de ruptura) +
// etiqueta BOS/CHoCH centrada sobre la linea (punto medio). Direccional: ruptura
// alcista por ENCIMA del nivel (style_label_down), bajista por DEBAJO
// (style_label_up). Alcista teal / bajista rojo; swing solido / interno punteado.
f_drawStructure(int pivotBarIdx, float level, int breakBarIdx, int kind, int dir, bool internal) =>
    col = dir == DIR_BULL ? color.teal : color.red
    txt = kind == KIND_CHOCH ? "CHoCH" : "BOS"
    line.new(pivotBarIdx, level, breakBarIdx, level, color = col, style = internal ? line.style_dashed : line.style_solid, width = internal ? 1 : 2)
    int midIdx = math.round((pivotBarIdx + breakBarIdx) / 2.0)
    label.new(midIdx, level, txt, style = dir == DIR_BULL ? label.style_label_down : label.style_label_up, color = color.new(col, 85), textcolor = col, size = internal ? size.tiny : size.small)

if i_showSwings and newSwingHigh
    f_drawSwing(bar_index - i_swingLen, swingHigh, swingHighKind)
if i_showSwings and newSwingLow
    f_drawSwing(bar_index - i_swingLen, swingLow, swingLowKind)

if i_showStruct and not na(evStructSwing)
    int originIdx = evStructSwing.dir == DIR_BULL ? structSwing.highBarIdx : structSwing.lowBarIdx
    f_drawStructure(originIdx, evStructSwing.price, evStructSwing.barIdx, evStructSwing.kind, evStructSwing.dir, false)
if i_showInternal and not na(evStructInt)
    int originIdx = evStructInt.dir == DIR_BULL ? structInternal.highBarIdx : structInternal.lowBarIdx
    f_drawStructure(originIdx, evStructInt.price, evStructInt.barIdx, evStructInt.kind, evStructInt.dir, true)

// === PANEL ===
// Esqueleto: confirma que el core carga y reporta el tamaño de los arrays
// globales. El panel completo (PINE-PLAN §5) llega en T14.
if i_showPanel and barstate.islast
    var table panel = table.new(position.top_right, 2, 6, border_width = 1)
    string biasTxt = structSwing.bias == DIR_BULL ? "Alcista" : structSwing.bias == DIR_BEAR ? "Bajista" : "—"
    color  biasCol = structSwing.bias == DIR_BULL ? color.teal : structSwing.bias == DIR_BEAR ? color.red : color.gray
    table.cell(panel, 0, 0, "SMC Engine — Visual", text_color = color.white, bgcolor = color.new(color.blue, 0))
    table.cell(panel, 1, 0, "estructura T03",      text_color = color.white, bgcolor = color.new(color.blue, 0))
    table.cell(panel, 0, 1, "Bias",    text_color = color.gray)
    table.cell(panel, 1, 1, biasTxt, text_color = biasCol)
    table.cell(panel, 0, 2, "Swings",  text_color = color.gray)
    table.cell(panel, 1, 2, str.tostring(array.size(SMC_swings)), text_color = color.gray)
    table.cell(panel, 0, 3, "Eventos", text_color = color.gray)
    table.cell(panel, 1, 3, str.tostring(array.size(SMC_events)), text_color = color.gray)
    table.cell(panel, 0, 4, "Zonas",   text_color = color.gray)
    table.cell(panel, 1, 4, str.tostring(array.size(SMC_zones)),  text_color = color.gray)
    table.cell(panel, 0, 5, "Pools",   text_color = color.gray)
    table.cell(panel, 1, 5, str.tostring(array.size(SMC_pools)),  text_color = color.gray)

// === ALERTAS ===
