indicator("SMC Engine — Visual", overlay = true, max_labels_count = 500, max_lines_count = 500, max_boxes_count = 500)

// === INPUTS ===
// Grupos canonicos (reglas-dev §1.3). Esqueleto: solo toggles base; cada
// concepto añade su grupo en su tarea (T02+).
GRP_STRUCT = "Estructura"
GRP_PANEL  = "Panel"
i_showPanel   = input.bool(true, "Mostrar panel de estado", group = GRP_PANEL)
i_swingLen    = input.int(5, "Swing length",    minval = 2, group = GRP_STRUCT)
i_internalLen = input.int(3, "Internal length", minval = 1, group = GRP_STRUCT)
i_showSwings  = input.bool(true, "Mostrar swings (HH/HL/LH/LL)", group = GRP_STRUCT)

// === LIBRARY CORE ===
// ---------------------------------------------------------------------------
// Nucleo de deteccion SMC/ICT. BYTE-IDENTICO en SMC-Visual y SMC-Strategy
// (lo vigila scripts/check-core-sync.ps1 — regla dura #2). El core NO dibuja y
// NO llama request.security(): solo tipos, constantes y funciones puras
// (entradas -> detecciones). La version exportable equivalente vive en
// SMC-Library.pine [D-PINE-01]. Esqueleto F1-S1.1-T01: tipos + constantes +
// arrays acotados; las f_detect*/f_compute* se añaden en T02+.
// ---------------------------------------------------------------------------
// Constantes 'kind' por categoria [reglas-dev §1.2 · PINE-PLAN §2]
KIND_OB          = 1
KIND_FVG         = 2
KIND_BREAKER     = 3
KIND_REJECTION   = 4
KIND_MITIGATION  = 5
KIND_OTE         = 6
KIND_GP          = 7
KIND_BOS          = 20
KIND_CHOCH        = 21
KIND_MSS          = 22
KIND_SWEEP        = 23
KIND_GRAB         = 24
KIND_JUDAS        = 25
KIND_DISPLACEMENT = 26
KIND_IDM          = 27
KIND_EMACROSS     = 28
KIND_EMABOUNCE    = 29
KIND_FLIP         = 30
KIND_HH = 40
KIND_HL = 41
KIND_LH = 42
KIND_LL = 43
DIR_BULL     = 1
DIR_BEAR     = -1
ZS_ACTIVE    = 0
ZS_PARTIAL   = 1
ZS_MITIGATED = 2
ZS_INVALID   = 3
MAX_ZONES  = 50
MAX_EVENTS = 100
MAX_SWINGS = 100
MAX_POOLS  = 50
type SMC_Zone
    float  top
    float  bottom
    int    dir
    int    barIdx
    int    barTime
    int    state        = 0
    float  mitigatedPct = 0.0
    string tf           = ""
    int    kind         = 0
type SMC_Event
    float  price
    int    dir
    int    barIdx
    int    barTime
    string tf   = ""
    int    kind = 0
type SMC_Swing
    float  price
    int    barIdx
    int    barTime
    int    kind   = 0
    bool   swept  = false
    bool   isHigh = false
type SMC_Pool
    float  level
    int    dir
    int    touches  = 1
    int    barTime
    bool   swept    = false
    string tf       = ""
type SMC_TFState
    int    bias           = 0
    float  lastBOSPrice   = na
    int    lastBOSDir     = 0
    int    lastBOSTime    = 0
    float  lastCHoCHPrice = na
    int    lastCHoCHDir   = 0
    int    lastCHoCHTime  = 0
    float  pdHigh         = na
    float  pdLow          = na
    float  ema20          = na
    float  ema50          = na
    float  ema200         = na
f_pushZone(array<SMC_Zone> a, SMC_Zone z, int maxN) =>
    array.push(a, z)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushEvent(array<SMC_Event> a, SMC_Event e, int maxN) =>
    array.push(a, e)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushSwing(array<SMC_Swing> a, SMC_Swing s, int maxN) =>
    array.push(a, s)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)
f_pushPool(array<SMC_Pool> a, SMC_Pool p, int maxN) =>
    array.push(a, p)
    if array.size(a) > maxN
        array.shift(a)
    array.size(a)

// --- Deteccion de swings estructurales [reglas-smc-ict §1.1] ---
// Pivote ESTRICTO: la barra 'len' atras es swing high si su high supera (>) el
// high de las 'len' barras a cada lado; swing low si su low es menor (<).
// Igualdad a cualquier lado => NO es swing (candidato EQH/EQL). Espejo exacto
// del detector golden scripts/ver05/detect.py:pivots (ADR-002). Anti-repaint:
// el llamador evalua bajo barstate.isconfirmed; el swing NACE 'len' barras
// atras (latencia inherente = len, deseable) y sus coords son las de esa barra
// central. Polaridad en isHigh; el kind (HH/HL/LH/LL) lo pone f_classifySwing.
// Devuelve SMC_Swing nuevo o na (un centro no puede ser high y low a la vez).
f_detectSwings(int len) =>
    SMC_Swing s = na
    bool isH = not na(high[len])
    bool isL = not na(low[len])
    float ch = high[len]
    float cl = low[len]
    for k = 1 to len
        if na(high[len + k]) or na(high[len - k]) or ch <= high[len + k] or ch <= high[len - k]
            isH := false
        if na(low[len + k]) or na(low[len - k]) or cl >= low[len + k] or cl >= low[len - k]
            isL := false
    if isH
        s := SMC_Swing.new(price = high[len], barIdx = bar_index[len], barTime = time[len], isHigh = true)
    else if isL
        s := SMC_Swing.new(price = low[len], barIdx = bar_index[len], barTime = time[len], isHigh = false)
    s

// --- Clasificacion HH/HL/LH/LL [reglas-smc-ict §1.2] ---
// Compara el swing recien confirmado con el PREVIO DEL MISMO TIPO (high vs
// high, low vs low) recorriendo prevSwings de atras hacia delante. HH/LH para
// highs, HL/LL para lows. Sin previo del mismo tipo o igualdad exacta => 0 (no
// reclasifica; candidato EQH/EQL, como 'H?'/'EQ-H' del golden detect.py). La
// polaridad vive en swing.isHigh, no en el kind devuelto.
f_classifySwing(SMC_Swing swing, array<SMC_Swing> prevSwings) =>
    int kind = 0
    if not na(swing)
        float prevPrice = na
        int n = array.size(prevSwings)
        if n > 0
            for i = n - 1 to 0
                SMC_Swing p = array.get(prevSwings, i)
                if p.isHigh == swing.isHigh
                    prevPrice := p.price
                    break
        if not na(prevPrice)
            if swing.isHigh
                kind := swing.price > prevPrice ? KIND_HH : swing.price < prevPrice ? KIND_LH : 0
            else
                kind := swing.price > prevPrice ? KIND_HL : swing.price < prevPrice ? KIND_LL : 0
    kind

// === DETECCIÓN TF PROPIO ===
// Estado global del chart actual. Arrays con prefijo SMC_ [PINE-PLAN §2].
var array<SMC_Swing> SMC_swings = array.new<SMC_Swing>()
var array<SMC_Event> SMC_events = array.new<SMC_Event>()
var array<SMC_Zone>  SMC_zones  = array.new<SMC_Zone>()
var array<SMC_Pool>  SMC_pools  = array.new<SMC_Pool>()

// Swings estructurales (escala swingLen). Solo en barra confirmada [D-PINE-03].
// El swing nace i_swingLen barras atras; se clasifica contra los ya confirmados
// (antes de apilarlo) y se apila FIFO. newSwing != na -> hubo swing esta barra
// (lo usa el DIBUJO mas abajo). El BOS/CHoCH interno (internalLen) entra en T03.
SMC_Swing newSwing = na
if barstate.isconfirmed
    SMC_Swing s = f_detectSwings(i_swingLen)
    if not na(s)
        s.kind := f_classifySwing(s, SMC_swings)
        f_pushSwing(SMC_swings, s, MAX_SWINGS)
        newSwing := s

// === MTF ===
// request.security D1/H1 (max 4 en Visual). Pendiente Sprint 1.4 (T13).

// === DIBUJO ===
// f_draw<Concepto>() por concepto, cada uno con su cuota de objetos
// [PINE-PLAN §5]. Solo Visual dibuja (D-PINE-01). Resto de conceptos: T03+.
// Etiqueta del swing recien confirmado (HH/HL/LH/LL). Helper de display (no
// pertenece al CORE). kind 0 (primer swing del tipo o empate) => sin etiqueta.
f_swingTag(int kind) =>
    kind == KIND_HH ? "HH" : kind == KIND_HL ? "HL" : kind == KIND_LH ? "LH" : kind == KIND_LL ? "LL" : ""
if i_showSwings and not na(newSwing)
    string tag = f_swingTag(newSwing.kind)
    if tag != ""
        label.new(chart.point.new(newSwing.barTime, na, newSwing.price), tag, xloc = xloc.bar_time, color = color(na), textcolor = newSwing.isHigh ? color.new(color.red, 0) : color.new(color.teal, 0), style = newSwing.isHigh ? label.style_label_down : label.style_label_up, size = size.tiny)

// === PANEL ===
// Esqueleto: confirma que el core carga y reporta el tamaño de los arrays
// globales. El panel completo (PINE-PLAN §5) llega en T14.
if i_showPanel and barstate.islast
    var table panel = table.new(position.top_right, 2, 5, border_width = 1)
    table.cell(panel, 0, 0, "SMC Engine — Visual", text_color = color.white, bgcolor = color.new(color.blue, 0))
    table.cell(panel, 1, 0, "T02 swings",          text_color = color.white, bgcolor = color.new(color.blue, 0))
    table.cell(panel, 0, 1, "Swings",  text_color = color.gray)
    table.cell(panel, 1, 1, str.tostring(array.size(SMC_swings)), text_color = color.gray)
    table.cell(panel, 0, 2, "Eventos", text_color = color.gray)
    table.cell(panel, 1, 2, str.tostring(array.size(SMC_events)), text_color = color.gray)
    table.cell(panel, 0, 3, "Zonas",   text_color = color.gray)
    table.cell(panel, 1, 3, str.tostring(array.size(SMC_zones)),  text_color = color.gray)
    table.cell(panel, 0, 4, "Pools",   text_color = color.gray)
    table.cell(panel, 1, 4, str.tostring(array.size(SMC_pools)),  text_color = color.gray)

// === ALERTAS ===
