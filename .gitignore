# Secrets — nunca commitear
.env
.env.local
.env*.local

# MCP config con keys
.mcp.json
*.local.json

# Herramientas que generan artefactos locales
.code-review-graph/
.task-master/
.context-mode/
.claude-mem/

# Archon: la APP vive fuera del repo (D:\CODE\Archon). En el proyecto, .archon/
# guarda workflows/commands/config RASTREABLES (WF-01 smc-sprint.yaml va ahi).
# Solo se ignora el estado local y artefactos que Archon genera por-run.
.archon/state/
.archon/artifacts/
.archon/*.local.yaml

